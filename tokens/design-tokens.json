{
  "$description": "HarmonyOS Design System - Single Source of Truth. Follows the W3C Design Tokens format.",
  "$format": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "primary":            { "$type": "color", "$value": { "light": "#2979FF", "dark": "#6EA8FF" } },
    "primaryContainer":   { "$type": "color", "$value": { "light": "#D6E4FF", "dark": "#00429A" } },
    "onPrimary":          { "$type": "color", "$value": { "light": "#FFFFFF", "dark": "#00285C" } },
    "secondary":          { "$type": "color", "$value": { "light": "#00C48C", "dark": "#4FE0B5" } },
    "secondaryContainer": { "$type": "color", "$value": { "light": "#C8F5E7", "dark": "#00513A" } },
    "success":            { "$type": "color", "$value": { "light": "#34C759", "dark": "#4ADE80" } },
    "warning":            { "$type": "color", "$value": { "light": "#FF9F0A", "dark": "#FBBF24" } },
    "danger":             { "$type": "color", "$value": { "light": "#FF3B30", "dark": "#FF6B6B" } },
    "info":               { "$type": "color", "$value": { "light": "#0A84FF", "dark": "#64B5FF" } },
    "surface":            { "$type": "color", "$value": { "light": "#FFFFFF", "dark": "#1E1E1E" } },
    "background":         { "$type": "color", "$value": { "light": "#F6F6F6", "dark": "#000000" } },
    "onSurface":          { "$type": "color", "$value": { "light": "#1A1A1A", "dark": "#F5F5F5" } },
    "onSurfaceVariant":   { "$type": "color", "$value": { "light": "#666666", "dark": "#A8A8A8" } },
    "outline":            { "$type": "color", "$value": { "light": "#E0E0E0", "dark": "#3A3A3A" } },
    "divider":            { "$type": "color", "$value": { "light": "#EEEEEE", "dark": "#2A2A2A" } },
    "mask":               { "$type": "color", "$value": { "light": "#00000073", "dark": "#00000099" } },
    "transparent":        { "$type": "color", "$value": { "light": "#00000000", "dark": "#00000000" } }
  },
  "space": {
    "none":  { "$type": "dimension", "$value": "0vp" },
    "xxs":   { "$type": "dimension", "$value": "4vp" },
    "xs":    { "$type": "dimension", "$value": "8vp" },
    "sm":    { "$type": "dimension", "$value": "12vp" },
    "md":    { "$type": "dimension", "$value": "16vp" },
    "lg":    { "$type": "dimension", "$value": "24vp" },
    "xl":    { "$type": "dimension", "$value": "32vp" },
    "xxl":   { "$type": "dimension", "$value": "40vp" },
    "3xl":   { "$type": "dimension", "$value": "48vp" },
    "4xl":   { "$type": "dimension", "$value": "56vp" },
    "5xl":   { "$type": "dimension", "$value": "64vp" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0vp" },
    "xs":   { "$type": "dimension", "$value": "4vp" },
    "sm":   { "$type": "dimension", "$value": "8vp" },
    "md":   { "$type": "dimension", "$value": "12vp" },
    "lg":   { "$type": "dimension", "$value": "16vp" },
    "xl":   { "$type": "dimension", "$value": "20vp" },
    "2xl":  { "$type": "dimension", "$value": "24vp" },
    "3xl":  { "$type": "dimension", "$value": "32vp" },
    "full": { "$type": "dimension", "$value": "999vp" }
  },
  "icon": {
    "xs":  { "$type": "dimension", "$value": "16vp" },
    "sm":  { "$type": "dimension", "$value": "20vp" },
    "md":  { "$type": "dimension", "$value": "24vp" },
    "lg":  { "$type": "dimension", "$value": "28vp" },
    "xl":  { "$type": "dimension", "$value": "32vp" },
    "xxl": { "$type": "dimension", "$value": "48vp" }
  },
  "font": {
    "$description": "字号/行高随 compact 密度切换（见各项 $extensions.compact，caption 不缩）；fontWeight 不变。",
    "family":        { "$type": "fontFamily", "$value": "HarmonyOS Sans" },
    "displayLarge":  { "$type": "typography", "$value": { "fontSize": "48fp", "lineHeight": "56fp", "fontWeight": 700 }, "$extensions": { "compact": { "fontSize": "40fp", "lineHeight": "48fp" } } },
    "displayMedium": { "$type": "typography", "$value": { "fontSize": "36fp", "lineHeight": "44fp", "fontWeight": 700 }, "$extensions": { "compact": { "fontSize": "32fp", "lineHeight": "40fp" } } },
    "headlineLarge": { "$type": "typography", "$value": { "fontSize": "30fp", "lineHeight": "38fp", "fontWeight": 600 }, "$extensions": { "compact": { "fontSize": "26fp", "lineHeight": "34fp" } } },
    "headlineMedium":{ "$type": "typography", "$value": { "fontSize": "24fp", "lineHeight": "32fp", "fontWeight": 600 }, "$extensions": { "compact": { "fontSize": "22fp", "lineHeight": "28fp" } } },
    "titleLarge":    { "$type": "typography", "$value": { "fontSize": "20fp", "lineHeight": "28fp", "fontWeight": 500 }, "$extensions": { "compact": { "fontSize": "18fp", "lineHeight": "24fp" } } },
    "titleMedium":   { "$type": "typography", "$value": { "fontSize": "18fp", "lineHeight": "26fp", "fontWeight": 500 }, "$extensions": { "compact": { "fontSize": "16fp", "lineHeight": "22fp" } } },
    "body":          { "$type": "typography", "$value": { "fontSize": "16fp", "lineHeight": "24fp", "fontWeight": 400 }, "$extensions": { "compact": { "fontSize": "14fp", "lineHeight": "20fp" } } },
    "bodySmall":     { "$type": "typography", "$value": { "fontSize": "14fp", "lineHeight": "20fp", "fontWeight": 400 }, "$extensions": { "compact": { "fontSize": "13fp", "lineHeight": "18fp" } } },
    "label":         { "$type": "typography", "$value": { "fontSize": "14fp", "lineHeight": "20fp", "fontWeight": 500 }, "$extensions": { "compact": { "fontSize": "13fp", "lineHeight": "18fp" } } },
    "caption":       { "$type": "typography", "$value": { "fontSize": "12fp", "lineHeight": "16fp", "fontWeight": 400 }, "$extensions": { "compact": { "fontSize": "12fp", "lineHeight": "16fp" } } }
  },
  "elevation": {
    "level0": { "$type": "shadow", "$value": { "offsetY": 0, "blur": 0,  "color": "#00000000" } },
    "level1": { "$type": "shadow", "$value": { "offsetY": 1, "blur": 3,  "color": "#00000014" } },
    "level2": { "$type": "shadow", "$value": { "offsetY": 2, "blur": 6,  "color": "#0000001A" } },
    "level3": { "$type": "shadow", "$value": { "offsetY": 4, "blur": 12, "color": "#00000024" } },
    "level4": { "$type": "shadow", "$value": { "offsetY": 8, "blur": 24, "color": "#0000002E" } }
  },
  "motion": {
    "instant":   { "$type": "duration", "$value": "100ms" },
    "fast":      { "$type": "duration", "$value": "200ms" },
    "normal":    { "$type": "duration", "$value": "250ms" },
    "slow":      { "$type": "duration", "$value": "300ms" },
    "extraSlow": { "$type": "duration", "$value": "400ms" },
    "easeStandard": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
    "easeOut":      { "$type": "cubicBezier", "$value": [0, 0, 0, 1] },
    "easeIn":       { "$type": "cubicBezier", "$value": [0.3, 0, 1, 1] }
  },
  "size": {
    "$description": "控件尺寸（vp），随 compact 密度切换：comfortable 常规 / compact 紧凑。字号/行高另见 font（同样随 compact 切换，caption 不缩）。",
    "minTouch":     { "$type": "dimension", "$value": "44vp", "$comment": "无障碍最小命中区；compact 下用 responseRegion 兜底" },
    "buttonLarge":  { "$type": "dimension", "$value": { "comfortable": "48vp", "compact": "40vp" } },
    "buttonMedium": { "$type": "dimension", "$value": { "comfortable": "40vp", "compact": "32vp" } },
    "buttonSmall":  { "$type": "dimension", "$value": { "comfortable": "32vp", "compact": "28vp" } },
    "field":        { "$type": "dimension", "$value": { "comfortable": "48vp", "compact": "40vp" } },
    "tabBar":       { "$type": "dimension", "$value": { "comfortable": "48vp", "compact": "40vp" } },
    "tabLabel":     { "$type": "dimension", "$value": { "comfortable": "46vp", "compact": "38vp" } },
    "rowMin":       { "$type": "dimension", "$value": { "comfortable": "56vp", "compact": "48vp" } },
    "menuItem":     { "$type": "dimension", "$value": { "comfortable": "40vp", "compact": "36vp" } },
    "avatarXs":     { "$type": "dimension", "$value": "24vp" },
    "avatarSm":     { "$type": "dimension", "$value": "32vp" },
    "avatarMd":     { "$type": "dimension", "$value": "40vp" },
    "avatarLg":     { "$type": "dimension", "$value": "48vp" },
    "avatarXl":     { "$type": "dimension", "$value": "64vp" },
    "badgeDot":     { "$type": "dimension", "$value": "8vp" },
    "badgeMin":     { "$type": "dimension", "$value": "16vp" },
    "tagHeight":    { "$type": "dimension", "$value": "24vp" },
    "sliderValueWidth": { "$type": "dimension", "$value": "40vp" },
    "skeletonLine": { "$type": "dimension", "$value": "16vp" },
    "progressRing": { "$type": "dimension", "$value": "56vp" },
    "progressTrack": { "$type": "dimension", "$value": "4vp" },
    "sheetHandleWidth": { "$type": "dimension", "$value": "32vp" },
    "sheetHandleHeight": { "$type": "dimension", "$value": "4vp" },
    "dialogMaxWidth": { "$type": "dimension", "$value": "400vp" },
    "menuMinWidth": { "$type": "dimension", "$value": "160vp" },
    "popoverMaxWidth": { "$type": "dimension", "$value": "240vp" }
  }
}
